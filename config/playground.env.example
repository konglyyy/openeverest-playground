# Local OpenEverest Playground config template.
# Copy this file to `config/playground.env` or let `task init` create/update that file for you.
# The repo root `.env` is ignored.

# Optional feature toggle for shared local backup testing.
ENABLE_BACKUP=false

# Host port used for the OpenEverest UI on localhost.
EVEREST_UI_PORT=8080

# Leave empty to use the OpenEverest chart default from the configured Helm repo.
EVEREST_HELM_CHART_VERSION=

# Leave empty to use the shared DB namespace chart default from the configured Helm repo.
EVEREST_DB_NAMESPACE_CHART_VERSION=
